meta {
  name: PUT profile.password
  type: http
  seq: 4
}

put {
  url: {{base_url}}/rest/v1/profile.password
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "type": "profile.password",
    "data": {
      "password_old": "{{password_old}}",
      "password_new": "{{password_new}}"
    }
  }
}

docs {
  Change current user password.
  Требует авторизации.
}
