meta {
  name: PUT orders.status
  type: http
  seq: 4
  tags: manual
}

put {
  url: {{base_url}}/rest/v1/orders.status
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "type": "orders.status",
    "data": {
      "id": {{order_id}},
      "status": "completed"
    }
  }
}

tests {
  test("status 200", function() {
    expect(res.status).to.equal(200);
  });
}

docs {
  Update order status by id.
  Требует роль UserPermissions = 1 или 2.
}
