meta {
  name: auth.login
  type: http
  seq: 1
}

post {
  url: {{base_url}}/rest/v1/auth.login
  body: json
  auth: none
}

body:json {
  {
    "type": "auth.login",
    "data": {
      "login": "{{user_login}}",
      "password": "{{user_password}}"
    }
  }
}

script:post-response {
  if (res.status === 200) {
    const data = res.body?.data;
    if (data?.accessToken)  bru.setVar("access_token",  data.accessToken);
    if (data?.refreshToken) bru.setVar("refresh_token", data.refreshToken);
  }
}

tests {
  test("status 200", function() {
    expect(res.status).to.equal(200);
  });
  test("returns accessToken", function() {
    expect(res.body.data).to.have.property("accessToken");
  });
  test("returns refreshToken", function() {
    expect(res.body.data).to.have.property("refreshToken");
  });
}

docs {
  Authenticate user and return JWT token.
  Сохраняет access_token и refresh_token в переменные окружения.
}
