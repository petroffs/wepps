meta {
  name: PUT orders
  type: http
  seq: 4
  tags: manual
}

put {
  url: {{base_url}}/rest/m2m/orders?id={{order_id}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:json {
  {
    "type": "orders",
    "data": {
      "status": "completed",
      "total": 9999.99
    }
  }
}

tests {
  test("status 200", function() {
    expect(res.status).to.equal(200);
  });
}

docs {
  Update order by id.
  Доступно только для M2M клиентов.
}
