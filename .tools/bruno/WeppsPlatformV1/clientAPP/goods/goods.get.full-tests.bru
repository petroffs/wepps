meta {
  name: GET goods (Full test suite)
  type: http
  seq: 1
}

get {
  url: {{base_url}}/rest/v1/goods?page=1&limit=24&category=8&f_1=cascissz|cmedl-kedl-21
  body: none
  auth: none
}

params:query {
  page: 1
  limit: 24
  category: 8
  f_1: cascissz|cmedl-kedl-21
  ~f_4: botilony|bruki
  ~sort: nameasc
  ~search: 
}

tests {
  // ========== УРОВЕНЬ 1: Базовая корректность ответа ==========
  
  test("L1: Returns 200 status", function() {
    expect(res.status).to.equal(200);
  });

  test("L1: Response has status field", function() {
    expect(res.body).to.have.property("status").that.equals(200);
  });

  test("L1: Response has message field", function() {
    expect(res.body).to.have.property("message");
  });

  test("L1: Response has data field", function() {
    expect(res.body).to.have.property("data");
  });

  // ========== УРОВЕНЬ 2: Структура данных ==========

  test("L2: Data is array", function() {
    expect(res.body.data).to.be.an("array");
  });

  test("L2: Each item has required fields", function() {
    res.body.data.forEach(item => {
      expect(item).to.have.property("Id");
      expect(item).to.have.property("Name");
      expect(item).to.have.property("Price");
      expect(item).to.have.property("Url");
      expect(item).to.have.property("IsHidden");
    });
  });

  test("L2: Pagination object present", function() {
    expect(res.body).to.have.property("pagination");
    expect(res.body.pagination).to.have.property("count");
    expect(res.body.pagination).to.have.property("page");
    expect(res.body.pagination).to.have.property("limit");
  });

  // ========== УРОВЕНЬ 3: Валидация значений ==========

  test("L3: All items have positive Id", function() {
    res.body.data.forEach(item => {
      expect(item.Id).to.be.a("number");
      expect(item.Id).to.be.greaterThan(0);
    });
  });

  test("L3: Name is non-empty string", function() {
    res.body.data.forEach(item => {
      expect(item.Name).to.be.a("string");
      expect(item.Name.length).to.be.greaterThan(0);
    });
  });

  test("L3: Price is non-negative number", function() {
    res.body.data.forEach(item => {
      expect(item.Price).to.be.a("number");
      expect(item.Price).to.be.at.least(0);
    });
  });

  test("L3: Url is valid HTTP(S) URL", function() {
    res.body.data.forEach(item => {
      expect(item.Url).to.match(/^https?:\/\//);
    });
  });

  test("L3: Images_FileUrl is valid URL (when present)", function() {
    res.body.data.forEach(item => {
      if (item.Images_FileUrl) {
        expect(item.Images_FileUrl).to.match(/^https?:\/\//);
      }
    });
  });

  test("L3: IsHidden is 0 for all items", function() {
    res.body.data.forEach(item => {
      expect(item.IsHidden).to.equal(0);
    });
  });

  test("L3: Pagination values are positive numbers", function() {
    expect(res.body.pagination.count).to.be.a("number").and.to.be.at.least(0);
    expect(res.body.pagination.page).to.be.a("number").and.to.be.greaterThan(0);
    expect(res.body.pagination.limit).to.be.a("number").and.to.be.greaterThan(0);
  });

  // ========== УРОВЕНЬ 4: Логика и связи данных ==========

  test("L4: Items match category filter", function() {
    if (req.getQueryParam("category")) {
      const requestedCategory = parseInt(req.getQueryParam("category"));
      res.body.data.forEach(item => {
        expect(item.NavigatorId).to.equal(requestedCategory);
      });
    }
  });

  test("L4: Page is less than or equal to max pages", function() {
    const { count, page, limit } = res.body.pagination;
    const maxPages = Math.ceil(count / limit);
    expect(page).to.be.lessThanOrEqual(maxPages);
  });

  test("L4: Returned items count matches limit", function() {
    const { count, limit } = res.body.pagination;
    const expectedCount = Math.min(limit, count);
    expect(res.body.data.length).to.be.lessThanOrEqual(expectedCount);
  });

  test("L4: W_Attributes is array when present", function() {
    res.body.data.forEach(item => {
      if (item.W_Attributes) {
        expect(item.W_Attributes).to.be.an("array");
        item.W_Attributes.forEach(attr => {
          expect(attr).to.have.property("id");
          expect(attr).to.have.property("name");
          expect(attr).to.have.property("values");
        });
      }
    });
  });

  // ========== УРОВЕНЬ 5: Граничные случаи и ошибки ==========

  test("L5: Handles empty results gracefully", function() {
    expect(res.body.data).to.be.an("array");
    if (res.body.data.length === 0) {
      expect(res.body.pagination.count).to.equal(0);
    }
  });
}

docs {
  Get list of goods with pagination and filtering.

  Parameters:
  - page: pagination page (default 1)
  - limit: items per page (default 20, max 100)
  - category: NavigatorId категории товаров
  - f_{PropertyId}: фильтр по свойству (несколько значений через |)
  - sort: priceasc | pricedesc | nameasc | (empty = по приоритету)
  - search: поиск по началу названия товара

  Response structure:
  {
    status: 200,
    message: "OK",
    data: [ { Id, Name, Price, Url, Images_FileUrl, NavigatorId, W_Attributes, IsHidden } ],
    pagination: { count, page, limit }
  }

  Test levels:
  L1: Basic response structure (status 200, fields present)
  L2: Data structure (array, required fields, pagination)
  L3: Value validation (positive IDs, valid URLs, ranges)
  L4: Logic (category matching, pagination consistency)
  L5: Edge cases (empty results, boundary values)
}
