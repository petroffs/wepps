meta {
  name: PUT users
  type: http
  seq: 4
}

put {
  url: {{base_url}}/rest/m2m/users?id={{user_id}}
  body: json
  auth: inherit
}

body:json {
  {
    "data": {
      "name": "Иван Иванов",
      "phone": "9001234567",
      "email": "user@example.com"
    }
  }
}

tests {
  test("status 200", function() {
    expect(res.status).to.equal(200);
  });
}

docs {
  Update user by id.
  Доступно только для M2M клиентов.
  Поля name, phone, email необязательные.
}
