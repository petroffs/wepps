meta {
  name: DELETE goods
  type: http
  seq: 4
}

delete {
  url: {{base_url}}/rest/m2m/goods
  body: json
  auth: inherit
}

params:query {
}

body:json {
  {
      "data": [
          {{goods_id}}
      ]
  }
}

tests {
  test("status 200", function() {
    expect(res.status).to.equal(200);
  });
}

docs {
  Delete goods item by id.
  Доступно только для M2M клиентов.
  
  Body format: {"data": [id1, id2, ...]} или одиночный ID через GET параметр ?id=
}
