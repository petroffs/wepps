meta {
  name: GET goods.item
  type: http
  seq: 1
}

get {
  url: {{base_url}}/rest/m2m/goods.item?id={{goods_id}}
  body: none
  auth: inherit
}

params:query {
  id: {{goods_id}}
}

tests {
  test("status 200", function() {
    expect(res.status).to.equal(200);
  });
  test("data has Id", function() {
    expect(res.body.data).to.have.property("Id");
  });
}

docs {
  Get single goods/product by id.
  Доступно только для M2M клиентов.
}
