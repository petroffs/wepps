Order Deny,Allow
Allow from All

<FilesMatch ".(?i:flv|gif|jpg|jpeg|png|ico|swf|js|css|pdf|woff)$">
Header set Cache-Control "max-age=2592000"
</FilesMatch>

AddDefaultCharset utf-8
Options -MultiViews -Indexes +FollowSymlinks

<FilesMatch "(.tpl|.conf|.sh|.idea)$">
    Order Deny,Allow
    Deny from All
</FilesMatch>

<FilesMatch "\.php$">
    <If "%{REQUEST_URI} =~ m#^/packages/vendor/#">
        Deny from all
    </If>
</FilesMatch>

RewriteEngine On
RewriteBase /
RedirectMatch 404 /\.git
RedirectMatch 404 /\.gitignore
RewriteCond %{THE_REQUEST} //
RewriteRule ^.*$ $0 [R=301,L,NE]
RewriteRule ^ext/(.+)\.(.+)\.(js|css)$ packages/WeppsExtensions/$1.$3 [L]
RewriteRule ^ext/(.+)$ packages/WeppsExtensions/$1 [L]
RewriteRule ^packages/WeppsAdmin/(.+)/(.+)\.(.+)\.(js|css)$ packages/WeppsAdmin/$1/$2.$4 [L]
RewriteRule ^pdf/([a-zA-Z0-9]+)/(.+).pdf$ packages/WeppsExtensions/Addons/Docs/Pdf/Request.php?id=$2&action=$1 [L]
RewriteRule ^f/(.+)$ packages/WeppsExtensions/Template/Request.php?action=files&fileUrl=/$1 [L]
RewriteRule ^rest/(.+)$ packages/WeppsExtensions/Addons/Rest/Request.php?params=$1&%{QUERY_STRING} [L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-l
RewriteRule ^pic/([a-zA-Z0-9]+)/(.+)$ packages/WeppsExtensions/Addons/Images/Request.php?fileUrl=$2&pref=$1 [L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-l
RewriteRule ^(.+)$ /?weppsurl=/$1&%{QUERY_STRING} [L]
